{
  "name": "zul-js",
  "version": "1.0.0",
  "description": "ZUL.js - Desktop Data Visualizer",
  "main": "ZUL.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "electron .",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "lucide": "^1.7.0",
    "mermaid": "^11.13.0",
    "tailwindcss": "^4.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "electron": "^41.0.0",
    "electron-builder": "^25.0.0",
    "vite": "^8.0.3"
  },
  "build": {
    "appId": "com.zuljs.app",
    "productName": "ZUL.js",
    "directories": {
      "output": "dist_desktop"
    },
    "files": [
      "dist/**/*",
      "ZUL.js"
    ],
    "win": {
      "target": "portable"
    },
    "mac": {
      "target": "dmg"
    }
  }
}
